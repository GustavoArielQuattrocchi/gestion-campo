    "test": "node scripts/run-tests.mjs",
    "lint": "eslint .",
    "audit:cuadros": "node scripts/audit-cuadros-map-vs-catalog.mjs",
    "sync:cuadros": "node scripts/sync-cuadros-catalog-from-mapa.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "typescript-eslint": "^8.34.0",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "~6.0.2",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@react-leaflet/core": "^3.0.0",
    "date-fns": "^4.1.0",
    "firebase": "^12.12.1",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.14.2",
    "react-webcam": "^7.2.0"
