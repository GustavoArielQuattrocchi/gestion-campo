{
  "name": "gestion-campo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/check-env.mjs && tsc && vite build",
    "deploy:firestore": "node scripts/print-firestore-deploy.mjs",
    "deploy": "npm run build && node scripts/deploy-hosting-rest.mjs",
    "deploy:cli": "npm run build && npx firebase-tools deploy --only hosting",
    "deploy:all": "npm run build && npx firebase-tools deploy --only hosting,firestore",
