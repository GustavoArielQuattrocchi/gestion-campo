rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Admin del escritorio: sesión con email/contraseña, dominio Salentein y email verificado.
    function esAdmin() {
      return isSignedIn()
        && request.auth.token.firebase.sign_in_provider == 'password'
        && request.auth.token.email_verified == true
        && request.auth.token.email.lower().matches('.*@salentein[.]com');
    }

    function operadorDoc() {
      return get(/databases/$(database)/documents/operadores/$(request.auth.uid));
    }

    function operadorRegistrado() {
      return isSignedIn() && operadorDoc().data != null;
    }

    function nombreOperadorAutenticado() {
      return operadorRegistrado() ? operadorDoc().data.nombre : '';
    }

    function validEstado() {
      return request.resource.data.estado in ['en_progreso', 'finalizada'];
    }

    function validTipo() {
      return request.resource.data.tipo in ['manual', 'mecanica'];
    }

    function validTareaBase() {
      let d = request.resource.data;
      return d.fincaId is string
        && d.fincaId.size() > 0
        && d.fincaNombre is string
        && d.fincaNombre.size() > 0
        && d.tarea is string
        && d.tarea.size() > 0
        && d.operador is string
        && d.operador.size() > 0
        && d.fechaInicio is timestamp
        && d.cuadros is list
        && (d.get('cuadroIds', null) == null || d.cuadroIds is list)
        && (d.get('cuadroIdsFinalizados', null) == null || d.cuadroIdsFinalizados is list)
        && (d.get('rendimientosDiarios', null) == null || d.rendimientosDiarios is list)
        && validEstado()
        && validTipo();
    }

    function validManual() {
      let d = request.resource.data;
      return d.tipo != 'manual'
        || (d.cuadrilla is string
          && d.cuadrilla.size() > 0
          && d.cantidadPersonas is int
          && d.cantidadPersonas >= 1);
    }

    function validMecanica() {
      let d = request.resource.data;
      return d.tipo != 'mecanica'
        || (d.persona is string
          && d.persona.size() > 0
          && d.maquinaria is string
          && d.maquinaria.size() > 0
          && (d.get('maquinariaModelo', null) == null || d.maquinariaModelo is string)
          && (d.get('maquinariaId', null) == null || d.maquinariaId is string));
    }

    function operadorCoincideEnAlta() {
      return request.resource.data.operador == nombreOperadorAutenticado();
    }

    function esOperadorDeLaTarea() {
      return operadorRegistrado()
        && resource.data.operador == nombreOperadorAutenticado();
    }

    function esSoloRegistroRendimiento() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['rendimientosDiarios', 'rendimiento'])
        && resource.data.estado == 'en_progreso'
        && request.resource.data.estado == 'en_progreso';
    }

    function validRegistroRendimiento() {
      return request.resource.data.rendimientosDiarios is list
        && request.resource.data.rendimientosDiarios.size() > 0
        && request.resource.data.rendimiento is string
        && request.resource.data.rendimiento.size() > 0;
    }

    function esActualizacionDashboard() {
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      return keys.hasOnly(['cuadroIdsFinalizados'])
        || keys.hasOnly(['estado', 'fechaFin']);
    }

    function esEdicionRendimientoDashboard() {
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      return keys.hasOnly(['rendimientosDiarios', 'rendimiento'])
        && request.resource.data.rendimientosDiarios is list
        && request.resource.data.rendimiento is string;
    }

    function validActualizacionDashboard() {
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      return (keys.hasOnly(['cuadroIdsFinalizados'])
          && resource.data.estado == 'en_progreso'
          && request.resource.data.estado == 'en_progreso'
          && request.resource.data.cuadroIdsFinalizados is list)
        || (keys.hasOnly(['estado', 'fechaFin'])
          && resource.data.estado == 'en_progreso'
          && request.resource.data.estado == 'finalizada'
          && request.resource.data.fechaFin is timestamp)
        || (keys.hasOnly(['estado', 'fechaFin'])
          && resource.data.estado == 'finalizada'
          && request.resource.data.estado == 'en_progreso');
    }

    match /operadores/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create, update: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.nombre is string
        && request.resource.data.nombre.size() > 0;
      allow delete: if false;
    }

    match /tareas/{tareaId} {
      allow read: if isSignedIn();
      allow create: if operadorRegistrado()
        && operadorCoincideEnAlta()
        && validTareaBase()
        && validManual()
        && validMecanica();
      allow update: if isSignedIn() && (
        (esOperadorDeLaTarea()
          && esSoloRegistroRendimiento()
          && validRegistroRendimiento())
        || (esActualizacionDashboard() && validActualizacionDashboard())
        || (esAdmin() && esEdicionRendimientoDashboard())
      );
      allow delete: if false;
    }

    match /informes_accidente/{informeId} {
      allow read: if isSignedIn();
      allow create: if operadorRegistrado()
        && request.resource.data.operador == nombreOperadorAutenticado()
        && request.resource.data.fincaId is string
        && request.resource.data.fincaId.size() > 0
        && request.resource.data.fincaNombre is string
        && request.resource.data.fincaNombre.size() > 0
        && request.resource.data.descripcion is string
        && request.resource.data.descripcion.size() > 0
        && request.resource.data.tieneFoto is bool
        && request.resource.data.creadoEn is timestamp;
      allow update, delete: if false;
    }

    function validParteDeLaboresBase() {
      let d = request.resource.data;
      return d.tareaId is string
        && d.tareaId.size() > 0
        && d.fincaId is string
        && d.fincaId.size() > 0
        && d.fincaNombre is string
        && d.fincaNombre.size() > 0
        && d.tarea is string
        && d.tarea.size() > 0
        && d.tipo in ['manual', 'mecanica']
        && d.operador is string
        && d.operador.size() > 0
        && d.rendimiento is string
        && d.rendimiento.size() > 0
        && (d.get('rendimientoCantidad', null) == null || d.rendimientoCantidad is number)
        && (d.get('rendimientoUnidad', null) == null
          || d.rendimientoUnidad in ['jornal', 'hileras', 'claros', 'plantas'])
        && d.cuadros is list
        && (d.get('cuadroIds', null) == null || d.cuadroIds is list)
        && d.cerradoEn is timestamp
        && validParteManual()
        && validParteMecanica();
    }

    function esEdicionRendimientoParte() {
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      return keys.hasOnly(['rendimiento', 'rendimientoCantidad', 'rendimientoUnidad'])
        && request.resource.data.rendimiento is string
        && request.resource.data.rendimiento.size() > 0
        && request.resource.data.rendimientoCantidad is number
        && request.resource.data.rendimientoUnidad in ['jornal', 'hileras', 'claros', 'plantas'];
    }

    function validParteManual() {
      let d = request.resource.data;
      return d.tipo != 'manual'
        || (d.cuadrilla is string
          && d.cuadrilla.size() > 0
          && d.cantidadPersonas is int
          && d.cantidadPersonas >= 1);
    }

    function validParteMecanica() {
      let d = request.resource.data;
      return d.tipo != 'mecanica'
        || (d.persona is string
          && d.persona.size() > 0
          && d.maquinaria is string
          && d.maquinaria.size() > 0
          && (d.get('maquinariaModelo', null) == null || d.maquinariaModelo is string)
          && (d.get('maquinariaId', null) == null || d.maquinariaId is string));
    }

    match /partes_labores/{parteId} {
      allow read: if isSignedIn();
      allow create: if operadorRegistrado()
        && request.resource.data.operador == nombreOperadorAutenticado()
        && validParteDeLaboresBase();
      allow update: if esAdmin() && esEdicionRendimientoParte();
      allow delete: if esAdmin();
    }

    match /ordenesCura/{ordenId} {
      allow read: if isSignedIn() && resource.data.owner_id == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.owner_id == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.owner_id == request.auth.uid;

      match /items/{itemId} {
        allow read: if isSignedIn()
          && get(/databases/$(database)/documents/ordenesCura/$(ordenId)).data.owner_id == request.auth.uid;
        // getAfter permite crear items en el mismo batch que la orden padre.
        allow create, update, delete: if isSignedIn()
          && getAfter(/databases/$(database)/documents/ordenesCura/$(ordenId)).data.owner_id == request.auth.uid;
      }
    }

    match /catalogoProductos/{productoId} {
      allow read, create, delete: if isSignedIn();
      allow update: if isSignedIn();
    }
  }
}
